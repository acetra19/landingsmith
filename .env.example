# Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# SerpAPI (alternative to Google Places)
SERPAPI_KEY=your_serpapi_key

# LLM for content generation (Groq = default, OpenAI = fallback)
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
# For OpenAI instead, use:
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# Railway deployment (single project for the whole app)
RAILWAY_API_TOKEN=your_railway_token
RAILWAY_APP_BASE_URL=https://your-app.up.railway.app
RAILWAY_PROJECT_ID=your_project_id

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
OUTREACH_FROM_EMAIL=outreach@yourdomain.com
OUTREACH_FROM_NAME=Your Company Name

# Database
WEBREACH_DATABASE_URL=sqlite:///data/outreach.db

# General
LOG_LEVEL=INFO
PIPELINE_BATCH_SIZE=10
OUTREACH_DAILY_LIMIT=50
FOLLOW_UP_DELAY_DAYS=3
MAX_FOLLOW_UPS=2
